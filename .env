# Images
SPARK_BASE_IMAGE=ghostwood/mbs-spark:1.0.7-protobuf
SPARK_CLUSTER_IMAGE=ghostwood/spark-notebook:0.0.1
JUPYTER_IMAGE=ghostwood/spark-notebook-jupyter:0.0.1

# Versions
SPARK_VERSION=3.5.7
PYSPARK_VERSION=3.5.7

# Namespaces
COMPUTE_NAMESPACE=compute
JUPYTER_NAMESPACE=notebook

# Jupyter
JUPYTER_HOST=notebook.k8s.tailnet

# Spark / Data Platform
HIVE_METASTORE_URIS=thrift://hive-metastore.metastore.svc.cluster.local:9083
S3A_ENDPOINT=http://minio-svc-private.storage.svc.cluster.local:9000
SPARK_WAREHOUSE_DIR=s3a://warehouse/

# MinIO/S3 demo credentials.
# Không dùng root credential trong production.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
